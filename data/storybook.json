			"richtext": "<p style=\"text-align: left;\"><span style=\"text-align: start; text-decoration-thickness: auto; text-decoration-style: solid; font-size: 12pt; line-height: 1;\">Once upon a time there was a girl called Little Red Riding</span><span style=\"caret-color: #000000; font-family: -webkit-standard; font-size: 0px; text-align: start;\">&nbsp;</span><span style=\"text-align: start; text-decoration-thickness: auto; text-decoration-style: solid; font-size: 12pt; line-height: 1;\">Hood. She lived with her mother in a village near a forest.</span></p>"
